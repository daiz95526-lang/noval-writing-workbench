# API credentials
ANTHROPIC_AUTH_TOKEN=your_api_key_here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash

# Local server
HOST=127.0.0.1
PORT=8010
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local project identity
PROJECT_ID=longzu6
PROJECT_TITLE=龙族 VI 续写工程

# Local data paths. Relative paths are resolved from the repository root.
DATA_DIR=./backend/data
PROJECTS_DIR=./backend/data/projects
# The following paths keep the existing single-project installation compatible.
CORPUS_SOURCE_DIR=./backend/data/books/longzu/source_txt
# Optional comma-separated roots that projects may reference as read-only corpora.
EXTERNAL_CORPUS_ROOTS=
CONTINUATION_PROJECT_DIR=./backend/data/projects/longzu_continuation
WRITING_PROJECT_DIR=./writing_projects/longzu6
